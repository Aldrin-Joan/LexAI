# ==============================================================================
# LegalTech Super-App Environment Configurations Template (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. FastAPI Production Auth & Security Configuration
# ------------------------------------------------------------------------------
SECRET_KEY=SUPER_SECRET_LEGAL_TECH_KEY_CHANGE_ME_IN_PROD
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# PostgreSQL database URL (Placeholder for future setup)
DATABASE_URL=postgresql://user:password@localhost:5432/legal_db

# ------------------------------------------------------------------------------
# 2. AI Model & API Configuration
# ------------------------------------------------------------------------------
# Google Gemini Setup (used in hybrid search modules)
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI API Key (used for Whisper Speech-To-Text translation)
OPENAI_API_KEY=your_openai_key_here

# ------------------------------------------------------------------------------
# 3. Hybrid Search & Vector Database Storage Locations
# ------------------------------------------------------------------------------
# Path to the 1.8GB judgments SQLite database
INDEX_DB_PATH=data/index.db

# ------------------------------------------------------------------------------
# 4. Tracing - Arize Phoenix OTEL Configuration
# ------------------------------------------------------------------------------
# Collector endpoint for exporting spans to Arize Phoenix dashboard
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces

# ------------------------------------------------------------------------------
# 5. Remote Session Storage (Optional)
# ------------------------------------------------------------------------------
# Upstash Redis settings (if running remote production sessions)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here
